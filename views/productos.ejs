<%- include('partials/header') %>
<main>
    <div class="stats-card" style="background: #1a1a2e; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #00ffcc;">
        <h3 style="color: #00ffcc; margin: 0;">📦 Stock Total: <%= totalProductos %> unidades</h3>
    </div>

    <h2>Gestión de Productos</h2>
    
    <section class="add-section">
        <h3>Añadir Nuevo Producto</h3>
        <form action="/agregar-producto" method="POST">
            <input type="number" name="codigo" placeholder="ID (CODIGO)" required>
            <input type="text" name="nombre" placeholder="Nombre" required>
            <input type="number" step="0.01" name="precio" placeholder="Precio" required>
            <input type="text" name="nif" placeholder="NIF Proveedor" required>
            <button type="submit">Guardar Item</button>
        </form>
    </section>

    <table>
        <thead>
            <tr>
                <th>ID</th><th>Nombre</th><th>Precio</th><th>Proveedor</th><th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% productos.forEach(p => { %>
                <tr>
                    <td><%= p.CODIGO %></td>
                    <td><%= p.NOMBRE %></td>
                    <td>$<%= p.PRECIO %></td>
                    <td><%= p.PROVEEDOR %></td>
                    <td><a href="/eliminar-producto/<%= p.CODIGO %>" class="btn-delete">Eliminar</a></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</main>
<%- include('partials/footer') %>